# =============================================================================
# Agent0 Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ---------------------
# Required (no defaults)
# ---------------------

# GitHub Personal Access Token with repo and notifications scopes
GITHUB_TOKEN=

# Anthropic API key for Claude Code
ANTHROPIC_API_KEY=

# GitHub username that Agent0 operates as (production)
GITHUB_USER=

# Comma-separated list of GitHub organizations Agent0 is allowed to act on
WHITELISTED_ORGS=

# ---------------------
# Dev instance (used by `make dev`)
# ---------------------
# Separate GitHub account for local development. The dev instance runs on
# port 9998 with these credentials, fully isolated from production.

# GitHub PAT for the dev account
GITHUB_TOKEN_DEV=

# GitHub username for the dev account
GITHUB_USER_DEV=

# ---------------------
# Optional (sensible defaults)
# ---------------------

# Seconds between notification polls (default: 30)
# POLL_INTERVAL=30

# Max seconds per Claude Code execution (default: 1800)
# EXECUTOR_TIMEOUT=1800

# Max agentic turns per Claude Code session (default: 100)
# MAX_TURNS=100

# Python log level (default: INFO)
# LOG_LEVEL=INFO

# Root directory for workspaces and audit logs (default: /data)
# DATA_DIR=/data

# Web server port (default: 9999)
# PORT=9999
